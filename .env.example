# PostgreSQL Database Connection
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secret_password_here
DB_NAME=forson_business_suite

# JWT Secret for Authentication
JWT_SECRET=a_very_long_and_random_string_for_security

# Backup Configuration
BACKUP_RETENTION_DAYS=7

# Meilisearch Configuration
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=another_strong_and_secret_key

# --- Meilisearch Advanced Configuration ---
# Set the environment: development, staging, or production
NODE_ENV=development

# Disable durable outbox worker for parts sync (debugging only)
DISABLE_MEILI_OUTBOX_WORKER=false

# Disable applications LISTEN/NOTIFY index sync listener (debugging only)
DISABLE_MEILI_APPLICATIONS_LISTENER=false

# Enable legacy parts LISTEN/NOTIFY listener (normally false when outbox worker is enabled)
ENABLE_LEGACY_MEILI_PART_LISTENER=false

# Retry logic for Meilisearch setup (optional, defaults shown)
MEILI_SETUP_MAX_RETRIES=4
MEILI_SETUP_RETRY_DELAY=200

# Typo tolerance configuration (optional, defaults shown)
MEILI_TYPO_ENABLED=true
MEILI_TYPO_MIN_WORD_SIZE=4
MEILI_TYPO_MIN_WORD_SIZE_TWO=8

# See MEILISEARCH_CONFIG.md for more details on these options and recommended values for each environment.

# --- AI Duplicate Verification Configuration ---
# Choose LLM Provider: 'google', 'openai', or 'openrouter'
LLM_PROVIDER=google

# Google Gemini API key configuration. Can be a single key, or a comma-separated list of keys for rotation.
GEMINI_API_KEY=
GEMINI_API_KEY_POOL=

# OpenAI API key and model selection
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenRouter API key and model selection
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat

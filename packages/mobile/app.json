{
  "expo": {
    "name": "FORSON",
    "slug": "mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/forson-icon.png",
    "splash": {
      "image": "./assets/images/forson-android-icon-foreground.png",
      "resizeMode": "contain",
      "backgroundColor": "#fbd602"
    },
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.forson.erp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fbd602",
        "foregroundImage": "./assets/images/forson-android-icon-foreground.png",
        "monochromeImage": "./assets/images/forson-android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.forson.erp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "./withAndroidBuildFixes",
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Allow Forson ERP to access your camera to scan barcodes.",
          "enableCodeScanner": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fbd602",
          "image": "./assets/images/forson-android-icon-foreground.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7be2cb55-55b5-4e31-92c9-2e0700db3486"
      }
    }
  }
}
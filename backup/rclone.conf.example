# rclone.conf — Google Drive remote configuration
# Generated by: rclone config (run on the server)
#
# SETUP STEPS:
#   1. SSH into the production server
#   2. Install rclone if not present: curl https://rclone.org/install.sh | sudo bash
#   3. Run: rclone config
#      - Choose: n (new remote)
#      - Name: gdrive
#      - Type: drive (Google Drive)
#      - Follow OAuth prompts (opens browser for Google account auth)
#   4. Copy the generated config to ./backup/rclone.conf
#      Default location: ~/.config/rclone/rclone.conf
#   5. Restart the backup container: docker compose restart forson_backup
#
# The backup script reads this file from /scripts/rclone.conf inside the container.
# If this file is missing, GDrive sync is skipped with a warning in the logs.

[gdrive]
type = drive
scope = drive
token = {}
# paste the full token JSON generated by rclone config here

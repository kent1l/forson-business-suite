# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env and fill in your production values
# SECURITY: Never commit .env files with real credentials to version control

# --- PostgreSQL Database ---
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=forson_business_suite

# --- Application Security ---
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS

# --- Node.js Environment ---
NODE_ENV=production

# --- Docker Registry (for image deployment) ---
# Leave empty to use Docker Hub defaults (kentonel/forson-*)
DOCKER_REGISTRY=
TAG=latest

# --- Meilisearch Configuration ---
MEILISEARCH_HOST=http://meilisearch:7700
# Generate with: openssl rand -base64 32
MEILISEARCH_MASTER_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_KEY

# Meilisearch Environment
MEILI_ENV=production
MEILI_NO_ANALYTICS=true

# Disable Meilisearch auto-listeners (set to true to disable sync)
DISABLE_MEILI_LISTENERS=false

# Retry logic for Meilisearch setup
MEILI_SETUP_MAX_RETRIES=5
MEILI_SETUP_RETRY_DELAY=500

# Typo tolerance configuration
MEILI_TYPO_ENABLED=true
MEILI_TYPO_MIN_WORD_SIZE=4
MEILI_TYPO_MIN_WORD_SIZE_TWO=8

# --- Backup Configuration ---
# Number of days to retain backups
BACKUP_RETENTION_DAYS=7

# Backup interval in seconds (default: 86400 = 24 hours)
BACKUP_INTERVAL_SECONDS=86400

# --- Optional: External Services ---
# Add your SMTP, payment gateway, or other service configurations here
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=smtp_password
